# App
NODE_ENV=production
RALPH_ADMIN_TOKEN=

# Supabase server-side only
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Worker
RALPH_RUNNER_ENABLED=0
RALPH_WORKER_INTERVAL_MS=5000
RALPH_TASK_TIMEOUT_MS=1800000

# Git safety
RALPH_GIT_ENABLED=0
RALPH_GIT_WRITE_ENABLED=0
RALPH_GIT_PUSH_ENABLED=0
RALPH_GIT_PR_ENABLED=0
RALPH_ALLOWED_REPOS=
RALPH_ALLOWED_COMMANDS=yarn lint,yarn typecheck,yarn build
RALPH_FORBIDDEN_PATHS=.env,.env.local,.ssh,id_rsa,id_ed25519

# Provider execution
RALPH_PROVIDER_CALLS_ENABLED=0
CODEX_COMMAND=codex exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox -
OPENCODE_GO_COMMAND=
MIMO_API_KEY=
MIMO_API_URL=
MIMO_MODEL=
MINIMAX_API_KEY=
MINIMAX_API_URL=
MINIMAX_MODEL=
ZAI_API_KEY=
ZAI_API_URL=
ZAI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=
DEEPSEEK_MODEL=

# GitHub publish helper. Do not commit real token.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=ralph-orchestrator
